@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger">@TempData["MensagemErro"]</div>
}
@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
}

@model List<Delivery.Models.Carrinho>

<h1 style="text-align:center;">Carrinho</h1>

@{
    decimal totalCarrinho = Model.Sum(x => x.TotalItem);
}

<h2 style="text-align:center;">
    Total: R$ @totalCarrinho
</h2>

@if (Model.Count == 0)
{
    <p>Carrinho vazio.</p>
}
else
{
    <table border="1" width="100%">
        <tr>
            <th>Imagem</th>
            <th>Item</th>
            <th>Unitário</th>
            <th>Quantidade</th>
            <th>Total</th>
            <th>Ações</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImagemArquivo))
                    {
                        <img src="~/@item.ImagemArquivo"
                             width="100"
                             height="100"
                             style="object-fit:cover; border-radius:10px;" />
                    }
                </td>

                <td>@item.Nome</td>
                <td>R$ @item.PrecoUnitario</td>

                <td>
                    <form asp-action="AtualizarQuantidade" method="get">
                        <input type="hidden" name="pratoId" value="@item.PratoId" />

                        <input type="number"
                               name="quantidade"
                               value="@item.Quantidade"
                               min="1" />

                        <button type="submit">Atualizar</button>
                    </form>
                </td>

                <td>R$ @item.TotalItem</td>

                <td>
                    <a asp-action="RemoverItem"
                       asp-route-pratoId="@item.PratoId">
                        🗑️
                    </a>
                </td>
            </tr>
        }
    </table>

    <br />

    <button onclick="confirmarLimpeza()">🧹 Limpar carrinho</button>

    <script>
        function confirmarLimpeza() {
            if (confirm("Tem certeza que deseja esvaziar o carrinho?")) {
                window.location.href = "/Listar/LimparCarrinho";
            }
        }
    </script>

    <br />
    <br />

    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#confirmarModal">
        Finalizar pedido
    </button>

    <div class="modal fade" id="confirmarModal" tabindex="-1" aria-labelledby="confirmarModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmarModalLabel">Confirmar Pedido</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    Deseja realmente finalizar o pedido?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form asp-action="FinalizarPedido" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-primary">Confirmar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>


    <a asp-controller="Home" asp-action="Index">
        <button>Voltar</button>
    </a>
}