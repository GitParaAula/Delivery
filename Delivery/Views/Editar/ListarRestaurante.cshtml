@model List<Delivery.Models.Restaurante>

<h1>Lista de Restaurantes</h1>

@if (Model.Count == 0)
{
    <p>Nenhum restaurante cadastrado.</p>
}
else
{
    @foreach (var restaurante in Model)
    {
        <div>

            <strong>@restaurante.Nome</strong>

            <a asp-controller="Editar"
               asp-action="Restaurante"
               asp-route-id="@restaurante.RestauranteId">
                <button>
                    Editar
                </button>
            </a>

        </div>

        <br />
    }
}

<br />

<a asp-controller="Home" asp-action="Index">
    <button>
        Voltar
    </button>
</a>