@model Delivery.Models.Admin

<h1>Cadastro de Admin</h1>

@if (ViewBag.Sucesso != null)
{
        <script>

            let voltar = confirm("Dados salvos com sucesso");

            if (voltar)
            {
                window.location.href = "/Home/Index";
            }

        </script>
}

@if (ViewBag.Erro != null)
{
        <div style="color:red;">
        @ViewBag.Erro
        </div>
}

<form asp-action="Admin" method="post">

    <input type="hidden" asp-for="AdminId" />

    <div>
        <label>Nome</label>
        <input type="text" asp-for="Nome" required />
    </div>

    <br />

    <div>
        <label>Senha</label>

        <input type="password"
               name="Senha"
               value="@Model.Senha"
               required />
    </div>

    <br />

    <div>
        <label>CPF</label>
        <input type="number" asp-for="Cpf" required />
    </div>

    <br />

    <button type="submit">
        Salvar edição
    </button>

</form>