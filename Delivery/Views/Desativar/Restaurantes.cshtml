@model List<Delivery.Models.Restaurante>

<h1>Lista de Restaurantes</h1>

@if (Model.Count == 0)
{
    <p>Nenhum restaurante cadastrado.</p>
}
else
{
    @foreach (var restaurante in Model)
    {
        <div>
            <strong>@restaurante.Nome</strong>

            <a href="/Desativar/SelecionarRestaurante?id=@restaurante.RestauranteId">
                <button type="button">
                    Prosseguir com esse restaurante
                </button>
            </a>
        </div>

        <br />
    }
}

<a href="/Home/Index">
    <button type="button">Voltar</button>
</a>